rules_version = '2';

// All writes go through Cloud Functions (admin SDK bypasses these rules).
// Client SDK can ONLY read its own data — never write directly.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // user profile + per-day quota counter
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;     // server-only via admin SDK
    }

    // generated poems history
    match /poems/{poemId} {
      allow read:   if isOwner(resource.data.uid);
      allow list:   if isSignedIn() &&
                     request.query.limit <= 50 &&
                     request.auth.uid == request.query.where[0][2];
      allow write:  if false;    // server-only via admin SDK
    }
  }
}
