# Local-only env. Never commit your real .env.
# For production, secrets live in Firebase Secret Manager (see functions/src/index.ts).

# Gemini API Key — get one at https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────────────────────────────
# Public values — also set as GitHub Actions repository VARIABLES (not
# secrets). They get inlined into the static export at build time and
# are visible in the JS bundle, which is fine: Firebase web config &
# Turnstile site key are designed to be public; access is gated by
# Firestore Security Rules + Cloudflare Turnstile + per-user quota.
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
